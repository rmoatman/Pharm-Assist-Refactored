# Copy this file to ".env" (in the server/ folder) and fill in real values.
# The .env file is gitignored so your secrets never get committed.

# Secret used to sign JWT auth tokens. Use a long, random string in production.
JWT_SECRET=change-me-to-a-long-random-string

# MongoDB connection string. Defaults to a local database if omitted.
MONGODB_URI=mongodb://localhost/pharm-assist

# --- Password reset email (Gmail + Nodemailer) ---
# Gmail address that sends reset emails, and a Google "App Password" (NOT your
# login password): Google Account -> Security -> 2-Step Verification -> App
# passwords. Paste the 16-char code with spaces removed. If these are unset the
# app still runs; it just logs the reset link instead of emailing it.
GMAIL_USER=youraddress@gmail.com
GMAIL_APP_PASSWORD=

# Base URL used to build the reset link in the email. Local dev = the React dev
# server; in production set this to your deployed site URL.
CLIENT_URL=http://localhost:3000

# Set to "production" when deploying (enables Secure/SameSite=None auth cookies).
# Leave unset for local development.
# NODE_ENV=production
